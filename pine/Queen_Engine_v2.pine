    SignalQueryResult signalResult = f_signalResultFromIndex(f_signalFindIndex(signalId))
    signalResult.found and signalResult.publicationStatus == SIGNAL_STATE_DISPATCHED_INTERNAL

f_signalCanPublish(string signalId) =>
    SignalQueryResult signalResult = f_signalResultFromIndex(f_signalFindIndex(signalId))
    signalResult.found and signalResult.publicationStatus == SIGNAL_STATE_VALIDATED

