f_signalFindBatch() =>
    g_signalRegistry.latestBatchEventCount > 1 ? f_signalFindLatest() : f_signalResultFromIndex(-1)

f_signalLastBatchPayload() =>
    g_signalRegistry.latestBatchPayload

f_signalUnconsumedEventCount() =>
    f_signalPendingEventCount()

f_signalDispatchQueueCount() =>
    f_signalPendingEventCount()

f_signalPayloadFallbackTier() =>
    g_signalRegistry.latestPayloadFallbackTier

f_signalWasLocallyDispatched(string signalId) =>
    SignalQueryResult signalResult = f_signalResultFromIndex(f_signalFindIndex(signalId))
    signalResult.found and signalResult.publicationStatus == SIGNAL_STATE_DISPATCHED_INTERNAL

f_signalPendingFindIndex(string eventId) =>
    int foundIndex = -1
    int index = 0
    while index < array.size(g_signalPendingRegistry.events)
        SignalPendingEvent pendingEvent = array.get(g_signalPendingRegistry.events, index)
        if pendingEvent.eventId == eventId
            foundIndex := index
            index := array.size(g_signalPendingRegistry.events)
        else
            index += 1
    foundIndex

f_signalPendingToBusEvent(SignalPendingEvent pendingEvent) =>
    StructureEventBusEvent.new(pendingEvent.eventId, pendingEvent.eventType, pendingEvent.direction, pendingEvent.sourceEngine, pendingEvent.sourceRegistryId, pendingEvent.eventBar, pendingEvent.eventTime, pendingEvent.price, pendingEvent.score, pendingEvent.state, false)

f_signalDiscoverPendingEvents() =>
    int totalEvents = array.size(g_structureEventBus.events)
    int startIndex = g_signalPendingRegistry.lastObservedBusSequence > totalEvents ? math.max(totalEvents - SIGNAL_EVENT_SCAN_LIMIT, 0) : math.max(g_signalPendingRegistry.lastObservedBusSequence, 0)
    int index = startIndex
    while index < totalEvents
        StructureEventBusEvent busEvent = array.get(g_structureEventBus.events, index)
        string signalType = f_signalTypeFromEvent(busEvent.eventType)
        bool eligibleSource = signalType != STATE_NONE and busEvent.sourceEngine != "Signal"
        bool notProcessed = not f_signalArrayContains(g_signalRegistry.processedSourceEventIds, busEvent.id)
        bool notPending = f_signalPendingFindIndex(busEvent.id) < 0
        bool storageAllowed = f_signalRealtimeAllowedForStorage()
        bool confirmed = f_signalConfirmedByPolicy(busEvent)
        if eligibleSource and notProcessed and notPending and storageAllowed and confirmed
            SignalPendingEvent pendingEvent = SignalPendingEvent.new(busEvent.id, busEvent.eventType, busEvent.sourceEngine, busEvent.sourceRegistryId, busEvent.direction, busEvent.barIndex, busEvent.eventTime, busEvent.price, busEvent.score, busEvent.state, bar_index, time_close, false, false)
            array.push(g_signalPendingRegistry.events, pendingEvent)
            if na(g_signalPendingRegistry.oldestPendingBusSequence)
                g_signalPendingRegistry.oldestPendingBusSequence := index
        index += 1
    g_signalPendingRegistry.lastObservedBusSequence := totalEvents
    while array.size(g_signalPendingRegistry.events) > 420
        array.shift(g_signalPendingRegistry.events)
    true

f_signalFinalizePendingEvent(string eventId, bool deferred) =>
    int pendingIndex = f_signalPendingFindIndex(eventId)
    if pendingIndex >= 0
        SignalPendingEvent pendingEvent = array.get(g_signalPendingRegistry.events, pendingIndex)
        pendingEvent.finalized := not deferred
        pendingEvent.deferred := deferred
        array.set(g_signalPendingRegistry.events, pendingIndex, pendingEvent)
        if not deferred
            g_signalPendingRegistry.latestFinalizedBusSequence := pendingIndex
    true

f_signalPendingEventCount() =>
    int count = 0
    int index = 0
    while index < array.size(g_signalPendingRegistry.events)
        SignalPendingEvent pendingEvent = array.get(g_signalPendingRegistry.events, index)
        if not pendingEvent.finalized
            count += 1
        index += 1
    count

f_signalDeferredEventCount() =>
    int count = 0
    int index = 0
    while index < array.size(g_signalPendingRegistry.events)
        SignalPendingEvent pendingEvent = array.get(g_signalPendingRegistry.events, index)
        if pendingEvent.deferred and not pendingEvent.finalized
            count += 1
        index += 1
    count

f_signalOldestPendingEventAge() =>
    int oldestAge = 0
    int index = 0
    while index < array.size(g_signalPendingRegistry.events)
        SignalPendingEvent pendingEvent = array.get(g_signalPendingRegistry.events, index)
        if not pendingEvent.finalized
            int age = math.max(bar_index - pendingEvent.discoveredBar, 0)
            oldestAge := oldestAge == 0 ? age : math.max(oldestAge, age)
        index += 1
    oldestAge

f_signalLastObservedBusSequence() =>
    g_signalPendingRegistry.lastObservedBusSequence

f_signalLifecycleDedupKey() =>
    g_signalRegistry.latestDeduplicationKey

f_signalSourceTraceabilityKey() =>
    SignalQueryResult latest = f_signalFindLatest()
    if latest.found
        SignalObject signalObject = array.get(g_signalRegistry.objects, latest.index)
        signalObject.sourceTraceabilityKey
    else
        STATE_NONE

f_signalCandidateFromPending(int pendingIndex, SignalPendingEvent pendingEvent) =>
    StructureEventBusEvent busEvent = f_signalPendingToBusEvent(pendingEvent)
    string signalType = f_signalTypeFromEvent(busEvent.eventType)
    string sourceId = f_signalExtractPrimaryId(busEvent.sourceRegistryId)
    string tradeId = busEvent.sourceEngine == "Trade" ? sourceId : STATE_NONE
    string entryId = busEvent.sourceEngine == "Entry" ? sourceId : STATE_NONE
    string actionability = f_signalActionability(signalType)
    SignalEventCandidate.new(true, false, pendingIndex, busEvent.id, busEvent.eventType, busEvent.sourceEngine, busEvent.sourceRegistryId, busEvent.barIndex, busEvent.eventTime, f_signalPriority(signalType), actionability, tradeId, entryId, f_signalLifecycleOrder(busEvent.eventType), busEvent.sourceEngine + "|" + busEvent.sourceRegistryId + "|" + busEvent.eventType)

f_signalCollectEligibleEvents() =>
    f_signalDiscoverPendingEvents()
    array<SignalEventCandidate> candidates = array.new<SignalEventCandidate>()
    int index = 0
    int deferredCount = 0
    while index < array.size(g_signalPendingRegistry.events)
        SignalPendingEvent pendingEvent = array.get(g_signalPendingRegistry.events, index)
        if not pendingEvent.finalized and array.size(candidates) < SIGNAL_MAX_BATCH_EVENTS
            pendingEvent.deferred := false
            array.set(g_signalPendingRegistry.events, index, pendingEvent)
            array.push(candidates, f_signalCandidateFromPending(index, pendingEvent))
        else if not pendingEvent.finalized
            pendingEvent.deferred := true
            array.set(g_signalPendingRegistry.events, index, pendingEvent)
            deferredCount += 1
        index += 1
    g_signalPendingRegistry.deferredCount := deferredCount
    int highestPriority = 0
    int candidateIndex = 0
    while candidateIndex < array.size(candidates)
        SignalEventCandidate candidate = array.get(candidates, candidateIndex)
        highestPriority := math.max(highestPriority, candidate.priority)
        candidateIndex += 1
    SignalEventBatch.new(candidates, array.size(candidates), highestPriority, SIGNAL_SAME_BAR_POLICY_BATCH)

f_signalCandidateBetter(SignalEventCandidate left, SignalEventCandidate right) =>
    not right.found ? true : left.eventBar < right.eventBar ? true : left.eventBar > right.eventBar ? false : left.eventTime < right.eventTime ? true : left.eventTime > right.eventTime ? false : left.priority > right.priority ? true : left.priority < right.priority ? false : left.lifecycleOrder < right.lifecycleOrder ? true : left.lifecycleOrder > right.lifecycleOrder ? false : left.busIndex < right.busIndex

f_signalNextCandidateIndex(array<SignalEventCandidate> candidates) =>
    int selectedIndex = -1
    SignalEventCandidate selected = SignalEventCandidate.new(false, false, -1, STATE_NONE, STATE_NONE, STATE_NONE, STATE_NONE, int(na), int(na), -1, STATE_NONE, STATE_NONE, STATE_NONE, 999, STATE_NONE)
    int index = 0
    while index < array.size(candidates)
        SignalEventCandidate candidate = array.get(candidates, index)
        if not candidate.selected and f_signalCandidateBetter(candidate, selected)
            selected := candidate
            selectedIndex := index
        index += 1
    selectedIndex

f_signalBuildBatchPayload(array<SignalObject> signals) =>
    string requestedChildren = ""
    string standardChildren = ""
    string compactChildren = ""
    string minimalChildren = ""
    int index = 0
    while index < array.size(signals)
        SignalObject signalObject = array.get(signals, index)
        string comma = index == 0 ? "" : ","
        requestedChildren := requestedChildren + comma + f_signalChildJson(signalObject, inp_signalMessageFormat == SIGNAL_FORMAT_VERBOSE_JSON)
        standardChildren := standardChildren + comma + f_signalChildJson(signalObject, false)
        compactChildren := compactChildren + comma + f_signalMinimalJson(signalObject)
        minimalChildren := minimalChildren + comma + f_signalMinimalJson(signalObject)
        index += 1
    string batchHead = "{" + "\"schema_version\":" + f_jsonString(SIGNAL_SCHEMA_VERSION) + ",\"engine\":\"Queen Engine\",\"event\":\"SIGNAL_BATCH\",\"symbol\":" + f_jsonString(syminfo.tickerid) + ",\"timeframe\":" + f_jsonString(timeframe.period) + ",\"bar_time\":" + f_jsonIntOrNull(time_close) + ",\"event_count\":" + str.tostring(array.size(signals)) + ",\"events\":["
    string requested = batchHead + requestedChildren + "]}"
    string standard = batchHead + standardChildren + "]}"
    string compact = batchHead + compactChildren + "]}"
    string minimal = batchHead + minimalChildren + "]}"
    string humanMessage = "Queen Engine - Signal batch: " + str.tostring(array.size(signals)) + " event(s)"
    str.length(requested) <= inp_signalMaxMessageLength ? f_signalPayloadResult(requested, inp_signalMessageFormat, requested, humanMessage, "REQUESTED_BATCH_FITS") : str.length(standard) <= inp_signalMaxMessageLength ? f_signalPayloadResult(standard, SIGNAL_FORMAT_STANDARD_JSON, requested, humanMessage, "FALLBACK_BATCH_STANDARD_JSON") : str.length(compact) <= inp_signalMaxMessageLength ? f_signalPayloadResult(compact, SIGNAL_FORMAT_COMPACT_JSON, requested, humanMessage, "FALLBACK_BATCH_COMPACT_JSON") : str.length(minimal) <= inp_signalMaxMessageLength ? f_signalPayloadResult(minimal, SIGNAL_FORMAT_MINIMAL_JSON, requested, humanMessage, "FALLBACK_BATCH_MINIMAL_JSON") : SignalPayloadResult.new(false, minimal, SIGNAL_FORMAT_FAILED_TOO_LARGE, str.length(minimal), humanMessage, SIGNAL_FORMAT_FAILED_TOO_LARGE, str.length(requested), str.length(minimal), "BATCH_PAYLOAD_TOO_LARGE")

f_signalCurrentBarHasType(string signalType) =>
    bool found = false
    int index = array.size(g_signalRegistry.objects) - 1
    while index >= 0
        SignalObject signalObject = array.get(g_signalRegistry.objects, index)
        bool localFinal = signalObject.publicationStatus == SIGNAL_STATE_DISPATCHED_INTERNAL or signalObject.publicationStatus == SIGNAL_STATE_STORED_NOT_DISPATCHED
        if not found and signalObject.publishedBar == bar_index and signalObject.signalType == signalType and localFinal
            found := true
        index -= 1
    found

f_signalCurrentBarHasActionability(string actionability) =>
    bool found = false
    int index = array.size(g_signalRegistry.objects) - 1
    while index >= 0
        SignalObject signalObject = array.get(g_signalRegistry.objects, index)
        bool localFinal = signalObject.publicationStatus == SIGNAL_STATE_DISPATCHED_INTERNAL or signalObject.publicationStatus == SIGNAL_STATE_STORED_NOT_DISPATCHED
        if not found and signalObject.publishedBar == bar_index and signalObject.actionability == actionability and localFinal
            found := true
        index -= 1
    found

f_signalBuildState() =>
    int failed = 0
    int index = 0
    while index < array.size(g_signalRegistry.objects)
        SignalObject signalObject = array.get(g_signalRegistry.objects, index)
        if signalObject.publicationStatus == SIGNAL_STATE_FAILED_VALIDATION or signalObject.publicationStatus == SIGNAL_STATE_FAILED_PAYLOAD
            failed += 1
        index += 1
    SignalQueryResult latest = f_signalFindLatest()
    SignalState.new(array.size(g_signalRegistry.objects), f_signalPublishedCount(), f_signalSuppressedCount(), failed, latest.signalId, latest.signalType, latest.actionability, latest.publicationStatus, g_signalRegistry.latestSourceEvent, g_signalRegistry.latestDeduplicationKey, g_signalRegistry.latestSuppressionReason, latest.publishedBar, g_signalRegistry.latestHumanMessage)

f_signalPublishLifecycle(SignalObject signalObject, string eventType) =>
    f_engineEventBusPublish(eventType, signalObject.direction, "Signal", signalObject.id, bar_index, time_close, signalObject.entryPrice, signalObject.confluenceScore, signalObject.publicationStatus)

f_signalUpdate(SignalState previousState) =>
    if inp_enableSignalEngine
        SignalEventBatch batch = f_signalCollectEligibleEvents()
        array<SignalObject> publishableSignals = array.new<SignalObject>()
        array<int> publishablePendingIndexes = array.new_int()
        int processedCandidates = 0
        while processedCandidates < batch.eventCount
            int candidateIndex = f_signalNextCandidateIndex(batch.candidates)
            if candidateIndex >= 0
                SignalEventCandidate candidate = array.get(batch.candidates, candidateIndex)
                candidate.selected := true
                array.set(batch.candidates, candidateIndex, candidate)
                SignalPendingEvent pendingEvent = array.get(g_signalPendingRegistry.events, candidate.busIndex)
                StructureEventBusEvent busEvent = f_signalPendingToBusEvent(pendingEvent)
                SignalObject signalObject = f_signalBuildFromEvent(busEvent)
                f_signalPublishLifecycle(signalObject, SIGNAL_EVENT_CREATED)
                SignalValidationResult validation = f_signalValidate(signalObject, busEvent)
                signalObject.publicationStatus := validation.valid ? SIGNAL_STATE_VALIDATED : validation.suppressionReason
                if validation.valid
                    f_signalPublishLifecycle(signalObject, SIGNAL_EVENT_VALIDATED)
                    signalObject.publicationStatus := SIGNAL_STATE_READY_FOR_DISPATCH
                    array.push(publishableSignals, signalObject)
                    array.push(publishablePendingIndexes, candidate.busIndex)
                else
                    signalObject.publishedBar := bar_index
                    signalObject.publishedTime := time_close
                    g_signalRegistry.latestSuppressionReason := validation.reason
                    g_signalRegistry.latestSourceEvent := busEvent.eventType
                    f_signalPublishLifecycle(signalObject, signalObject.publicationStatus == SIGNAL_STATE_SUPPRESSED_DUPLICATE ? SIGNAL_EVENT_SUPPRESSED_DUPLICATE : signalObject.publicationStatus == SIGNAL_STATE_SUPPRESSED_CONFIGURATION ? SIGNAL_EVENT_SUPPRESSED_CONFIGURATION : SIGNAL_EVENT_FAILED_VALIDATION)
                    array.push(g_signalRegistry.objects, signalObject)
                    array.push(g_signalRegistry.processedSourceEventIds, busEvent.id)
                    f_signalCommitDeduplicationKey(signalObject.deduplicationKey)
                    f_signalFinalizePendingEvent(busEvent.id, false)
                    g_signalRegistry.primarySignalId := signalObject.id
            processedCandidates += 1
        if array.size(publishableSignals) > 0
            SignalPayloadResult payload = array.size(publishableSignals) == 1 ? f_signalBuildPayload(array.get(publishableSignals, 0)) : f_signalBuildBatchPayload(publishableSignals)
            SignalDispatchResult dispatch = f_signalDispatchPayload(payload.payload, payload.valid)
            int signalIndex = 0
            while signalIndex < array.size(publishableSignals)
                SignalObject signalObject = array.get(publishableSignals, signalIndex)
                SignalPendingEvent pendingEvent = array.get(g_signalPendingRegistry.events, array.get(publishablePendingIndexes, signalIndex))
                StructureEventBusEvent busEvent = f_signalPendingToBusEvent(pendingEvent)
                signalObject.publicationStatus := dispatch.state
                signalObject.publishedBar := dispatch.dispatchBar
                signalObject.publishedTime := dispatch.dispatchTime
                if not payload.valid
                    signalObject.publicationStatus := SIGNAL_STATE_FAILED_PAYLOAD
                array.push(g_signalRegistry.objects, signalObject)
                array.push(g_signalRegistry.processedSourceEventIds, busEvent.id)
                f_signalCommitDeduplicationKey(signalObject.deduplicationKey)
                f_signalFinalizePendingEvent(busEvent.id, false)
                g_signalRegistry.primarySignalId := signalObject.id
                g_signalRegistry.latestPayload := payload.payload
                g_signalRegistry.latestBatchPayload := array.size(publishableSignals) > 1 ? payload.payload : g_signalRegistry.latestBatchPayload
                g_signalRegistry.latestHumanMessage := payload.humanMessage
                g_signalRegistry.latestDeduplicationKey := signalObject.deduplicationKey
                g_signalRegistry.latestSuppressionReason := dispatch.reason + "|" + payload.fallbackReason
                g_signalRegistry.latestSourceEvent := busEvent.eventType
                g_signalRegistry.latestPayloadFallbackTier := payload.fallbackTier
                g_signalRegistry.latestOriginalPayloadLength := payload.originalLength
                g_signalRegistry.latestFinalPayloadLength := payload.finalLength
                g_signalRegistry.latestBatchEventCount := array.size(publishableSignals)
                f_signalPublishLifecycle(signalObject, dispatch.alertCalled ? SIGNAL_EVENT_PUBLISHED : (payload.valid ? SIGNAL_EVENT_STORED_NOT_DISPATCHED : SIGNAL_EVENT_FAILED_PAYLOAD))
                signalIndex += 1
        while array.size(g_signalRegistry.objects) > 220
            array.shift(g_signalRegistry.objects)
        while array.size(g_signalRegistry.deduplicationKeys) > 420
            array.shift(g_signalRegistry.deduplicationKeys)
        while array.size(g_signalRegistry.processedSourceEventIds) > 420
            array.shift(g_signalRegistry.processedSourceEventIds)
    f_signalBuildState()

f_signalReset() =>
    int index = 0
    while index < array.size(g_signalRegistry.objects)
        SignalObject signalObject = array.get(g_signalRegistry.objects, index)
        signalObject.active := false
        signalObject.archived := true
        signalObject.publicationStatus := SIGNAL_STATE_ARCHIVED
        array.set(g_signalRegistry.objects, index, signalObject)
        index += 1
    SignalState.new(array.size(g_signalRegistry.objects), f_signalPublishedCount(), f_signalSuppressedCount(), 0, STATE_NONE, STATE_NONE, STATE_NONE, SIGNAL_STATE_ARCHIVED, STATE_NONE, STATE_NONE, STATE_NONE, int(na), STATE_NONE)

f_signalGetState() =>
    g_signalState

f_clearSignalVisuals() =>
    while array.size(g_signalVisuals.labels) > 0
        label visualLabel = array.pop(g_signalVisuals.labels)
        f_removeManagedLabel(visualLabel)
        f_deleteLabel(visualLabel)
    true

f_signalDraw() =>
    if barstate.islast
        f_clearSignalVisuals()
    if barstate.islast and inp_engineEnabled and inp_enableSignalEngine and inp_showSignalVisuals
        SignalQueryResult latest = f_signalFindLatest()
        if latest.found
            string labelText = latest.signalType + " | " + latest.actionability + " | " + latest.publicationStatus
            color labelColor = latest.actionability == ACTIONABILITY_ACTIONABLE ? color.new(COLOR_DISPLACEMENT, 25) : latest.actionability == ACTIONABILITY_TERMINAL ? color.new(COLOR_BEAR, 25) : color.new(COLOR_NEUTRAL, 40)
            label statusLabel = f_registerLabel(label.new(time_close, close, labelText, xloc=xloc.bar_time, style=label.style_label_left, textcolor=COLOR_PANEL_TEXT, color=labelColor, size=size.tiny))
            array.push(g_signalVisuals.labels, statusLabel)
            if latest.signalType == SIGNAL_ENTRY_EXECUTED or latest.signalType == SIGNAL_TRADE_OPENED
                string executionText = latest.direction == STRUCTURE_DIRECTION_BULLISH ? "LONG EXECUTED" : latest.direction == STRUCTURE_DIRECTION_BEARISH ? "SHORT EXECUTED" : "EXECUTED"
                label execLabel = f_registerLabel(label.new(time_close, latest.entryPrice, executionText, xloc=xloc.bar_time, style=label.style_label_up, textcolor=COLOR_PANEL_TEXT, color=latest.direction == STRUCTURE_DIRECTION_BULLISH ? color.new(COLOR_BULL, 15) : color.new(COLOR_BEAR, 15), size=size.small))
                array.push(g_signalVisuals.labels, execLabel)
    true

