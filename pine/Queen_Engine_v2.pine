    table.cell(g_statusTable, 0, 115, "Current Target", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 115, f_priceText(snapshot.tradeCurrentTarget), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 116, "Duration", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 116, str.tostring(snapshot.tradeDurationBars), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 117, "Risk", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 117, str.tostring(snapshot.tradeCurrentRisk, "#.00"), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 118, "Reward", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 118, str.tostring(snapshot.tradeCurrentReward, "#.00"), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 119, "Remaining", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 119, str.tostring(snapshot.tradeRemainingPosition, "#") + "%", text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 120, "Trade Event", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 120, snapshot.latestTradeEvent, text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 121, "Signal Total", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 121, str.tostring(snapshot.signalTotalCount), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 122, "Sig Pub/Sup", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 122, str.tostring(snapshot.signalPublishedCount) + " / " + str.tostring(snapshot.signalSuppressedCount), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 123, "Sig Failed", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 123, str.tostring(snapshot.signalFailedCount), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 124, "Source Event", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 124, snapshot.latestSignalSourceEvent, text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 125, "Signal ID", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 125, snapshot.latestSignalId, text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 126, "Signal Type", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 126, snapshot.latestSignalType, text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 127, "Actionability", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 127, snapshot.latestSignalActionability, text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 128, "Pub State", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 128, snapshot.latestSignalState, text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 129, "Payload Schema", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 129, snapshot.latestPayloadSchemaVersion, text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 130, "Payload Format", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 130, snapshot.latestPayloadFormat, text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 131, "Dedup Key", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 131, snapshot.latestDeduplicationKey, text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 132, "Suppress", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 132, snapshot.latestSuppressionReason, text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 133, "Alert Bar", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 133, f_jsonIntOrNull(snapshot.latestAlertBar), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 134, "Message", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 134, str.substring(snapshot.latestHumanMessage, 0, math.min(str.length(snapshot.latestHumanMessage), 80)), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 135, "Source Decision", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 135, "PREVIOUS ENGINES", text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 136, "Signal Engine", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 136, "COMMUNICATION ONLY", text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 137, "Alert Master", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 137, inp_enableTradingViewAlerts ? "alert() enabled" : "stored only", text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 138, "Fallback Tier", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 138, g_signalRegistry.latestPayloadFallbackTier, text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 139, "Payload Len", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 139, str.tostring(g_signalRegistry.latestFinalPayloadLength) + " / " + str.tostring(g_signalRegistry.latestOriginalPayloadLength), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 140, "Batch Count", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 140, str.tostring(g_signalRegistry.latestBatchEventCount), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 141, "Unconsumed", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 141, str.tostring(f_signalUnconsumedEventCount()), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 142, "Pending/Def", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 142, str.tostring(f_signalPendingEventCount()) + " / " + str.tostring(f_signalDeferredEventCount()), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 143, "Oldest Age", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 143, str.tostring(f_signalOldestPendingEventAge()), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 0, 144, "Bus Cursor", text_color=COLOR_MUTED_TEXT, bgcolor=COLOR_PANEL_BG)
    table.cell(g_statusTable, 1, 144, str.tostring(f_signalLastObservedBusSequence()), text_color=COLOR_PANEL_TEXT, bgcolor=COLOR_PANEL_BG)

f_clearStatusPanel() =>
    for rowIndex = 0 to 147
        table.cell(g_statusTable, 0, rowIndex, "", bgcolor=color.new(color.black, 100))
        table.cell(g_statusTable, 1, rowIndex, "", bgcolor=color.new(color.black, 100))

//==================================================
// 06. MULTI-TIMEFRAME CONTEXT ENGINE
//==================================================
// HTF cache rule: future engines consume g_context* or f_htfCacheGet* helpers.
// Do not add duplicate request.security() calls when the required timeframe data already exists here.
[weeklyOpen, weeklyHigh, weeklyLow, weeklyClose, weeklyTime, previousWeeklyOpen, previousWeeklyHigh, previousWeeklyLow, previousWeeklyClose, previousWeeklyTime] = request.security(syminfo.tickerid, "W", [open, high, low, close, time, open[1], high[1], low[1], close[1], time[1]], lookahead=barmerge.lookahead_off)
[dailyOpen, dailyHigh, dailyLow, dailyClose, dailyTime, previousDailyOpen, previousDailyHigh, previousDailyLow, previousDailyClose, previousDailyTime] = request.security(syminfo.tickerid, "D", [open, high, low, close, time, open[1], high[1], low[1], close[1], time[1]], lookahead=barmerge.lookahead_off)
[fourHourOpen, fourHourHigh, fourHourLow, fourHourClose, fourHourTime, previousFourHourOpen, previousFourHourHigh, previousFourHourLow, previousFourHourClose, previousFourHourTime] = request.security(syminfo.tickerid, "240", [open, high, low, close, time, open[1], high[1], low[1], close[1], time[1]], lookahead=barmerge.lookahead_off)
[oneHourOpen, oneHourHigh, oneHourLow, oneHourClose, oneHourTime, previousOneHourOpen, previousOneHourHigh, previousOneHourLow, previousOneHourClose, previousOneHourTime] = request.security(syminfo.tickerid, "60", [open, high, low, close, time, open[1], high[1], low[1], close[1], time[1]], lookahead=barmerge.lookahead_off)
[fifteenMinuteOpen, fifteenMinuteHigh, fifteenMinuteLow, fifteenMinuteClose, fifteenMinuteTime, previousFifteenMinuteOpen, previousFifteenMinuteHigh, previousFifteenMinuteLow, previousFifteenMinuteClose, previousFifteenMinuteTime] = request.security(syminfo.tickerid, "15", [open, high, low, close, time, open[1], high[1], low[1], close[1], time[1]], lookahead=barmerge.lookahead_off)
[fiveMinuteOpen, fiveMinuteHigh, fiveMinuteLow, fiveMinuteClose, fiveMinuteTime, previousFiveMinuteOpen, previousFiveMinuteHigh, previousFiveMinuteLow, previousFiveMinuteClose, previousFiveMinuteTime] = request.security(syminfo.tickerid, "5", [open, high, low, close, time, open[1], high[1], low[1], close[1], time[1]], lookahead=barmerge.lookahead_off)
[monthlyOpen, monthlyHigh, monthlyLow, monthlyClose, monthlyTime, previousMonthlyOpen, previousMonthlyHigh, previousMonthlyLow, previousMonthlyClose, previousMonthlyTime] = request.security(syminfo.tickerid, "M", [open, high, low, close, time, open[1], high[1], low[1], close[1], time[1]], lookahead=barmerge.lookahead_off)

if inp_engineEnabled
    g_contextWeekly := f_contextUpdate("W", weeklyOpen, weeklyHigh, weeklyLow, weeklyClose, weeklyTime, previousWeeklyOpen, previousWeeklyHigh, previousWeeklyLow, previousWeeklyClose, previousWeeklyTime)
    g_contextDaily := f_contextUpdate("D", dailyOpen, dailyHigh, dailyLow, dailyClose, dailyTime, previousDailyOpen, previousDailyHigh, previousDailyLow, previousDailyClose, previousDailyTime)
    g_context4H := f_contextUpdate("240", fourHourOpen, fourHourHigh, fourHourLow, fourHourClose, fourHourTime, previousFourHourOpen, previousFourHourHigh, previousFourHourLow, previousFourHourClose, previousFourHourTime)
    g_context1H := f_contextUpdate("60", oneHourOpen, oneHourHigh, oneHourLow, oneHourClose, oneHourTime, previousOneHourOpen, previousOneHourHigh, previousOneHourLow, previousOneHourClose, previousOneHourTime)
    g_context15M := f_contextUpdate("15", fifteenMinuteOpen, fifteenMinuteHigh, fifteenMinuteLow, fifteenMinuteClose, fifteenMinuteTime, previousFifteenMinuteOpen, previousFifteenMinuteHigh, previousFifteenMinuteLow, previousFifteenMinuteClose, previousFifteenMinuteTime)
    g_context5M := f_contextUpdate("5", fiveMinuteOpen, fiveMinuteHigh, fiveMinuteLow, fiveMinuteClose, fiveMinuteTime, previousFiveMinuteOpen, previousFiveMinuteHigh, previousFiveMinuteLow, previousFiveMinuteClose, previousFiveMinuteTime)
    g_contextMonthly := f_contextUpdate("M", monthlyOpen, monthlyHigh, monthlyLow, monthlyClose, monthlyTime, previousMonthlyOpen, previousMonthlyHigh, previousMonthlyLow, previousMonthlyClose, previousMonthlyTime)

if not inp_engineEnabled
    g_contextWeekly := f_contextReset("W")
    g_contextDaily := f_contextReset("D")
    g_context4H := f_contextReset("240")
    g_context1H := f_contextReset("60")
    g_context15M := f_contextReset("15")
    g_context5M := f_contextReset("5")
    g_contextMonthly := f_contextReset("M")

f_contextDraw()

//==================================================
// 07. SESSION ENGINE
//==================================================
bool isInAsiaSession = inp_enableAsiaSession and not na(time(timeframe.period, inp_asiaSession, f_resolvedTimezone()))
bool isInLondonSession = inp_enableLondonSession and not na(time(timeframe.period, inp_londonSession, f_resolvedTimezone()))
bool isInNewYorkSession = inp_enableNewYorkSession and not na(time(timeframe.period, inp_newYorkSession, f_resolvedTimezone()))

if inp_engineEnabled
    g_asiaSession := f_sessionUpdate(g_asiaSession, "Asia", inp_enableAsiaSession, isInAsiaSession)
    g_londonSession := f_sessionUpdate(g_londonSession, "London", inp_enableLondonSession, isInLondonSession)
    g_newYorkSession := f_sessionUpdate(g_newYorkSession, "New York", inp_enableNewYorkSession, isInNewYorkSession)

if not inp_engineEnabled
    g_asiaSession := f_sessionReset("Asia", inp_enableAsiaSession)
    g_londonSession := f_sessionReset("London", inp_enableLondonSession)
    g_newYorkSession := f_sessionReset("New York", inp_enableNewYorkSession)

g_asiaVisual := f_sessionDraw(g_asiaSession, g_asiaVisual, COLOR_SESSION_ASIA)
g_londonVisual := f_sessionDraw(g_londonSession, g_londonVisual, COLOR_SESSION_LONDON)
g_newYorkVisual := f_sessionDraw(g_newYorkSession, g_newYorkVisual, COLOR_SESSION_NEW_YORK)

//==================================================
// 07B. PREVIOUS LEVEL ENGINE
//==================================================
if inp_engineEnabled
    g_previousDayHigh := f_previousLevelsUpdate("Previous Day High", "D", f_htfCacheGetPreviousHigh("D"), true)
    g_previousDayLow := f_previousLevelsUpdate("Previous Day Low", "D", f_htfCacheGetPreviousLow("D"), true)
    g_previousWeekHigh := f_previousLevelsUpdate("Previous Week High", "W", f_htfCacheGetPreviousHigh("W"), true)
    g_previousWeekLow := f_previousLevelsUpdate("Previous Week Low", "W", f_htfCacheGetPreviousLow("W"), true)
    g_previousMonthHigh := f_previousLevelsUpdate("Previous Month High", "M", f_htfCacheGetPreviousHigh("M"), true)
    g_previousMonthLow := f_previousLevelsUpdate("Previous Month Low", "M", f_htfCacheGetPreviousLow("M"), true)

if not inp_engineEnabled
    g_previousDayHigh := f_previousLevelsReset("Previous Day High", "D", true)
    g_previousDayLow := f_previousLevelsReset("Previous Day Low", "D", true)
    g_previousWeekHigh := f_previousLevelsReset("Previous Week High", "W", true)
    g_previousWeekLow := f_previousLevelsReset("Previous Week Low", "W", true)
    g_previousMonthHigh := f_previousLevelsReset("Previous Month High", "M", true)
    g_previousMonthLow := f_previousLevelsReset("Previous Month Low", "M", true)

f_previousLevelsDraw()

//==================================================
// 07C. PIVOT PIPELINE
//==================================================
// Centralized confirmed-pivot producer. Engines must consume g_pivotPipeline rather than calling pivot functions.
g_pivotPipeline := f_pivotPipelineUpdate()

if not inp_engineEnabled
    g_pivotPipeline := f_pivotPipelineReset()

//==================================================
// 08. LIQUIDITY ENGINE
//==================================================
if inp_engineEnabled
    f_liquidityUpdate(ta.atr(inp_atrLength))

if not inp_engineEnabled
    f_liquidityReset()

f_liquidityDraw()

//==================================================
// 09. MARKET STRUCTURE ENGINE
//==================================================
if inp_engineEnabled
    g_structureState := f_structureUpdate(g_structureState, ta.atr(inp_atrLength))

if not inp_engineEnabled
    g_structureState := f_structureReset()

f_structureDraw()

//==================================================
// 10. INSTITUTIONAL IMPULSE ENGINE
//==================================================
// Phase 5 implements Institutional Impulse. Displacement is a strict impulse classification, not a separate engine.
if inp_engineEnabled
    g_impulseState := f_impulseUpdate(g_impulseState, ta.atr(inp_atrLength))
    g_structureState := f_impulseIntegrateMSS(g_structureState)

if not inp_engineEnabled
    g_impulseState := f_impulseReset()

f_impulseDraw()

//==================================================
// 11. INSTITUTIONAL IMBALANCE ENGINE
//==================================================
// Phase 6 implements classic bullish/bearish FVG only. Other imbalance classes remain reserved.
if inp_engineEnabled
    g_imbalanceState := f_imbalanceUpdate(g_imbalanceState, ta.atr(inp_atrLength))

if not inp_engineEnabled
    g_imbalanceState := f_imbalanceReset()

f_imbalanceDraw()

//==================================================
// 12. ORDER BLOCK ENGINE
//==================================================
// Phase 7 implements institutional Order Blocks only. Breaker behavior remains a candidate state.
if inp_engineEnabled
    g_orderBlockState := f_orderBlockUpdate(g_orderBlockState, ta.atr(inp_atrLength))

if not inp_engineEnabled
    g_orderBlockState := f_orderBlockReset()

f_orderBlockDraw()

//==================================================
// 13. BREAKER AND MITIGATION ENGINE
//==================================================
// Breaker and mitigation state remains independent; later engines consume it as context only.
if inp_engineEnabled
    g_breakerState := f_breakerUpdate(g_breakerState)
    g_mitigationState := f_mitigationUpdate(g_mitigationState)

if not inp_engineEnabled
    g_breakerState := f_breakerReset()
    g_mitigationState := f_mitigationReset()

f_breakerDraw()
f_mitigationDraw()

//==================================================
// 14. PREMIUM AND DISCOUNT ENGINE
//==================================================
// Phase 9 provides institutional dealing range, premium/discount, equilibrium, and OTE context only.
if inp_engineEnabled
    g_dealingRangeState := f_dealingRangeUpdate(g_dealingRangeState, ta.atr(inp_atrLength))

if not inp_engineEnabled
    g_dealingRangeState := f_dealingRangeReset()

f_dealingRangeDraw()

//==================================================
// 15. CONFLUENCE AND SETUP QUALIFICATION ENGINE
//==================================================
// Phase 10 qualifies setup context from existing engine state only. Scores describe quality; mandatory conditions decide validity.
if inp_engineEnabled
    g_confluenceState := f_confluenceUpdate(g_confluenceState)

if not inp_engineEnabled
    g_confluenceState := f_confluenceReset()

f_confluenceDraw()

//==================================================
// 16. INSTITUTIONAL ENTRY ENGINE
//==================================================
// Phase 11 transforms qualified setup context into READY_TO_EXECUTE or WAIT. It does not place trades.
if inp_engineEnabled
    g_entryState := f_entryUpdate(g_entryState)

if not inp_engineEnabled
    g_entryState := f_entryReset()

f_entryDraw()

//==================================================
// 17. INSTITUTIONAL TRADE MANAGEMENT ENGINE
//==================================================
// Phase 12 manages executed trades only. It does not execute broker orders or search for setups.
if inp_engineEnabled
    g_tradeState := f_tradeUpdate(g_tradeState)

if not inp_engineEnabled
    g_tradeState := f_tradeReset()

f_tradeDraw()

//==================================================
// 18. INSTITUTIONAL SIGNAL AND ALERT ENGINE
//==================================================
// Phase 13 communicates confirmed upstream decisions only. It does not create market analysis.
if inp_engineEnabled and inp_enableSignalEngine
    g_signalState := f_signalUpdate(g_signalState)

if not inp_engineEnabled or not inp_enableSignalEngine
    g_signalState := f_signalReset()

f_signalDraw()

g_signalAnyEntryExecuted := inp_engineEnabled and inp_enableSignalEngine and f_signalCurrentBarHasType(SIGNAL_ENTRY_EXECUTED)
g_signalAnyTradeOpened := inp_engineEnabled and inp_enableSignalEngine and f_signalCurrentBarHasType(SIGNAL_TRADE_OPENED)
g_signalAnyTradeManagementUpdate := inp_engineEnabled and inp_enableSignalEngine and f_signalCurrentBarHasActionability(ACTIONABILITY_MANAGEMENT)
g_signalAnyTradeClosed := inp_engineEnabled and inp_enableSignalEngine and f_signalCurrentBarHasActionability(ACTIONABILITY_TERMINAL)
g_signalAnySetupQualified := inp_engineEnabled and inp_enableSignalEngine and f_signalCurrentBarHasType(SIGNAL_SETUP_QUALIFIED)

//==================================================
// 19. ORDER FLOW ENGINE
//==================================================
// A later phase may add integrated order-flow state.

//==================================================
// 20. CRT ENGINE
//==================================================
// A later phase may add Candle Range Theory reference, manipulation, re-entry, and expansion logic.

//==================================================
// 21. OPTIONAL SMT ENGINE
//==================================================
// A later phase may add optional SMT, disabled by default.

//==================================================
// 22. VOLUME CONFIRMATION ENGINE
//==================================================
// A later phase may add volume proxy confirmation where available.

//==================================================
// 23. SETUP SCORING ENGINE
//==================================================
// A later phase may add transparent modular setup scoring from 0 to 100.

//==================================================
// 24. ENTRY ENGINE
//==================================================
// A later phase may add precision, balanced, and aggressive entry profiles.

//==================================================
// 25. STOP-LOSS ENGINE
//==================================================
// A later phase may add structural invalidation and volatility-aware stop validation.

//==================================================
// 26. TARGET ENGINE
//==================================================
// A later phase may add market-objective target selection and RR calculations.

//==================================================
// 27. TRADE STATE MANAGEMENT
//==================================================
// A later phase will add trade lifecycle and simulated outcome state.

//==================================================
// 28. VISUAL RENDERING ENGINE
//==================================================
atrValue = ta.atr(inp_atrLength)
bool hasEngineJustDisabled = not inp_engineEnabled and g_wasEngineEnabled

if hasEngineJustDisabled
    f_clearManagedObjects()
    g_asiaVisual := f_resetSessionVisual()
    g_londonVisual := f_resetSessionVisual()
    g_newYorkVisual := f_resetSessionVisual()
    g_liquidityVisuals := LiquidityVisualState.new(array.new_line(), array.new_label())
    g_structureVisuals := StructureVisualState.new(array.new_line(), array.new_label())
    g_impulseVisuals := ImpulseVisualState.new(array.new_label())
    g_imbalanceVisuals := ImbalanceVisualState.new(array.new_box(), array.new_line(), array.new_label())
    g_orderBlockVisuals := OrderBlockVisualState.new(array.new_box(), array.new_line(), array.new_label())
    g_breakerVisuals := BreakerVisualState.new(array.new_box(), array.new_line(), array.new_label())
    g_dealingRangeVisuals := DealingRangeVisualState.new(array.new_box(), array.new_line(), array.new_label())
    g_confluenceVisuals := ConfluenceVisualState.new(array.new_label())
    g_entryVisuals := EntryVisualState.new(array.new_label())
    g_tradeVisuals := TradeVisualState.new(array.new_label())
    g_signalVisuals := SignalVisualState.new(array.new_label())

EngineSnapshot currentSnapshot = f_newEngineSnapshot(atrValue)

if inp_engineEnabled and inp_showDevStatus and barstate.islast
    f_renderStatusPanel(currentSnapshot)

if (not inp_engineEnabled or not inp_showDevStatus) and barstate.islast
    f_clearStatusPanel()

g_wasEngineEnabled := inp_engineEnabled

//==================================================
// 29. ALERTS AND JSON PAYLOADS
//==================================================
alertcondition(g_signalAnyEntryExecuted, "Queen Engine - Any Entry Executed", "Queen Engine entry executed. Use Any alert() function call for dynamic JSON payloads.")
alertcondition(g_signalAnyTradeOpened, "Queen Engine - Any Trade Opened", "Queen Engine trade opened. Use Any alert() function call for dynamic JSON payloads.")
alertcondition(g_signalAnyTradeManagementUpdate, "Queen Engine - Any Trade Management Update", "Queen Engine trade management update. Use Any alert() function call for dynamic JSON payloads.")
alertcondition(g_signalAnyTradeClosed, "Queen Engine - Any Trade Closed", "Queen Engine trade terminal event. Use Any alert() function call for dynamic JSON payloads.")
alertcondition(g_signalAnySetupQualified, "Queen Engine - Any Institutional Setup Qualified", "Queen Engine institutional setup qualified. This is preparation only, not an executed trade.")

//==================================================
// 30. COMPACT DASHBOARD
//==================================================
// The Phase 13 development-status panel remains separate from the future final dashboard.

//==================================================
// 31. DEBUG AND VALIDATION TOOLS
//==================================================
plot(inp_debugMode ? array.size(g_managedLines) : na, title="QE v2 managed lines", color=color.new(COLOR_NEUTRAL, 100), display=display.data_window)
plot(inp_debugMode ? array.size(g_managedBoxes) : na, title="QE v2 managed boxes", color=color.new(COLOR_NEUTRAL, 100), display=display.data_window)
plot(inp_debugMode ? array.size(g_managedLabels) : na, title="QE v2 managed labels", color=color.new(COLOR_NEUTRAL, 100), display=display.data_window)
