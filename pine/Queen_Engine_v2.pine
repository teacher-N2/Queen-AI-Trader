//@version=6
indicator("Queen Engine v2.0", "Queen Engine v2.0", overlay=true, max_lines_count=300, max_boxes_count=150, max_labels_count=150, max_polylines_count=50)

//==================================================
// 01. HEADER AND INDICATOR DECLARATION
//==================================================
// Queen Engine v2.0 is an institutional market-analysis framework.
// Phase 13 adds an institutional communication layer. It publishes confirmed upstream events only.

//==================================================
// 02. USER INPUTS
//==================================================
const string GROUP_GENERAL = "01. General"
const string GROUP_DISPLAY = "02. Chart Display"
const string GROUP_PERFORMANCE = "03. Performance"
const string GROUP_RISK = "04. Risk Foundation"
const string GROUP_DEBUG = "05. Development / Debug"
const string GROUP_SESSIONS = "06. Sessions"
const string GROUP_LIQUIDITY = "07. Liquidity"
const string GROUP_STRUCTURE = "08. Structure"
const string GROUP_IMPULSE = "09. Impulse"
const string GROUP_IMBALANCE = "10. Imbalance"
const string GROUP_ORDER_BLOCK = "11. Order Blocks"
const string GROUP_BREAKER_MITIGATION = "12. Breakers / Mitigation"
const string GROUP_DEALING_RANGE = "13. Dealing Range"
const string GROUP_CONFLUENCE = "14. Confluence"
const string GROUP_ENTRY = "15. Entry"
const string GROUP_TRADE = "16. Trade Management"
const string GROUP_SIGNAL = "17. Signals"

inp_engineEnabled = input.bool(true, "Enable Queen Engine", group=GROUP_GENERAL)
inp_entryProfile = input.string("Balanced", "Entry profile", options=["Precision", "Balanced", "Aggressive"], group=GROUP_GENERAL)
inp_timezone = input.string("Etc/UTC", "Institutional timezone", options=["Etc/UTC", "America/New_York", "Europe/London", "Asia/Qatar", "Exchange"], group=GROUP_GENERAL)
inp_primarySymbolMode = input.string("Auto", "Instrument mode", options=["Auto", "Gold", "Nasdaq", "Other liquid market"], group=GROUP_GENERAL)

inp_showSessions = input.bool(true, "Show sessions", group=GROUP_DISPLAY)
inp_showLiquidity = input.bool(true, "Show liquidity", group=GROUP_DISPLAY)
inp_showStructureLabels = input.bool(true, "Show structure labels", group=GROUP_DISPLAY)
inp_showFvgs = input.bool(true, "Show FVG zones", group=GROUP_DISPLAY)
inp_showOrderBlocks = input.bool(true, "Show order blocks", group=GROUP_DISPLAY)
inp_showBreakers = input.bool(true, "Show breakers", group=GROUP_DISPLAY)
inp_showCrt = input.bool(false, "Show CRT", group=GROUP_DISPLAY)
inp_showSmt = input.bool(false, "Show SMT", group=GROUP_DISPLAY)
inp_showEntryLevels = input.bool(true, "Show entry levels", group=GROUP_DISPLAY)
inp_showDashboard = input.bool(true, "Show compact dashboard", group=GROUP_DISPLAY)

inp_recentSessionRanges = input.int(4, "Recent session ranges", minval=1, maxval=8, group=GROUP_PERFORMANCE)
inp_maxActiveLines = input.int(180, "Maximum active lines", minval=50, maxval=300, group=GROUP_PERFORMANCE)
inp_maxActiveBoxes = input.int(80, "Maximum active boxes", minval=20, maxval=150, group=GROUP_PERFORMANCE)
inp_maxActiveLabels = input.int(80, "Maximum active labels", minval=20, maxval=150, group=GROUP_PERFORMANCE)
inp_liquiditySensitivity = input.float(1.0, "Liquidity sensitivity", minval=0.25, maxval=3.0, step=0.25, group=GROUP_PERFORMANCE)

inp_atrLength = input.int(14, "ATR length", minval=5, maxval=100, group=GROUP_RISK)
inp_atrBufferMultiplier = input.float(0.35, "ATR stop buffer", minval=0.05, maxval=3.0, step=0.05, group=GROUP_RISK)
inp_minimumRrScalping = input.float(2.0, "Minimum RR scalping", minval=1.0, maxval=10.0, step=0.25, group=GROUP_RISK)
inp_minimumRrIntraday = input.float(3.0, "Minimum RR intraday", minval=1.0, maxval=15.0, step=0.25, group=GROUP_RISK)

inp_debugMode = input.bool(false, "Debug mode", group=GROUP_DEBUG)
inp_showDevStatus = input.bool(true, "Show Phase 13 status panel", group=GROUP_DEBUG)
// inp_showDevStatus controls this temporary build panel; inp_showDashboard is reserved for the final trading dashboard.

inp_enableAsiaSession = input.bool(true, "Enable Asia", group=GROUP_SESSIONS)
inp_asiaSession = input.session("0000-0600", "Asia time window", group=GROUP_SESSIONS)
inp_enableLondonSession = input.bool(true, "Enable London", group=GROUP_SESSIONS)
inp_londonSession = input.session("0700-1100", "London time window", group=GROUP_SESSIONS)
inp_enableNewYorkSession = input.bool(true, "Enable New York", group=GROUP_SESSIONS)
inp_newYorkSession = input.session("1300-1700", "New York time window", group=GROUP_SESSIONS)
inp_showSessionHighLow = input.bool(true, "Draw session high/low", group=GROUP_SESSIONS)
inp_showSessionMidpoint = input.bool(true, "Draw session midpoint", group=GROUP_SESSIONS)
inp_showSessionLabels = input.bool(true, "Draw session labels", group=GROUP_SESSIONS)

inp_liquidityDisplayMode = input.string("Major + EQ", "Liquidity display", options=["Major only", "Minor only", "Major + EQ", "All"], group=GROUP_LIQUIDITY)
inp_maxVisibleLiquidityLevels = input.int(24, "Maximum visible liquidity levels", minval=5, maxval=80, group=GROUP_LIQUIDITY)
inp_majorSwingLength = input.int(10, "Major swing length", minval=3, maxval=30, group=GROUP_LIQUIDITY)
inp_minorSwingLength = input.int(3, "Minor swing length", minval=2, maxval=12, group=GROUP_LIQUIDITY)
inp_equalLiquidityAtrTolerance = input.float(0.12, "EQH/EQL ATR tolerance", minval=0.02, maxval=1.0, step=0.01, group=GROUP_LIQUIDITY)
inp_showPreviousLiquidity = input.bool(true, "Show previous D/W/M liquidity", group=GROUP_LIQUIDITY)
inp_showSessionLiquidity = input.bool(true, "Show session liquidity", group=GROUP_LIQUIDITY)
inp_liquidityCleanupInterval = input.int(50, "Cleanup interval bars", minval=10, maxval=500, group=GROUP_LIQUIDITY)
inp_liquidityMaxTotalObjects = input.int(350, "Maximum registry objects", minval=100, maxval=1000, group=GROUP_LIQUIDITY)
inp_liquidityMaxArchivedObjects = input.int(120, "Maximum archived objects", minval=20, maxval=500, group=GROUP_LIQUIDITY)
inp_liquidityArchiveAgeBars = input.int(1200, "Archived retention bars", minval=100, maxval=10000, group=GROUP_LIQUIDITY)

inp_structureBreakMode = input.string("Close + Displacement", "Break confirmation", options=["Wick", "Close", "Close + Displacement"], group=GROUP_STRUCTURE)
inp_internalStructureLength = input.int(3, "Internal pivot sensitivity", minval=2, maxval=12, group=GROUP_STRUCTURE)
inp_externalStructureLength = input.int(10, "External pivot sensitivity", minval=4, maxval=40, group=GROUP_STRUCTURE)
inp_showStructureVisuals = input.bool(true, "Draw structure", group=GROUP_STRUCTURE)
inp_showInternalStructure = input.bool(false, "Draw internal structure", group=GROUP_STRUCTURE)
inp_maxVisibleStructureObjects = input.int(28, "Maximum visible structure objects", minval=6, maxval=80, group=GROUP_STRUCTURE)
inp_structureCleanupInterval = input.int(75, "Structure cleanup interval bars", minval=10, maxval=500, group=GROUP_STRUCTURE)
inp_structureMaxPivots = input.int(260, "Maximum structure pivots", minval=80, maxval=800, group=GROUP_STRUCTURE)
inp_structureMaxEvents = input.int(180, "Maximum structure events", minval=40, maxval=500, group=GROUP_STRUCTURE)
inp_structureArchiveAgeBars = input.int(1800, "Archived structure retention bars", minval=200, maxval=20000, group=GROUP_STRUCTURE)

inp_impulseMinScore = input.float(52.0, "Minimum confirmed impulse score", minval=0.0, maxval=100.0, step=1.0, group=GROUP_IMPULSE)
inp_impulseHighQualityScore = input.float(72.0, "High-quality impulse score", minval=50.0, maxval=100.0, step=1.0, group=GROUP_IMPULSE)
inp_impulseDisplacementScore = input.float(82.0, "Displacement score", minval=60.0, maxval=100.0, step=1.0, group=GROUP_IMPULSE)
inp_impulseMomentumThreshold = input.float(1.1, "Momentum threshold ATR", minval=0.25, maxval=4.0, step=0.05, group=GROUP_IMPULSE)
inp_impulseLookback = input.int(3, "Momentum lookback", minval=1, maxval=12, group=GROUP_IMPULSE)
inp_impulseMaxObjects = input.int(220, "Maximum impulse objects", minval=50, maxval=600, group=GROUP_IMPULSE)
inp_showImpulseVisuals = input.bool(true, "Draw impulse labels", group=GROUP_IMPULSE)
inp_showImpulseScoreLabels = input.bool(false, "Draw impulse scores", group=GROUP_IMPULSE)

inp_imbalanceMinScore = input.float(55.0, "Minimum imbalance score", minval=0.0, maxval=100.0, step=1.0, group=GROUP_IMBALANCE)
inp_imbalanceInstitutionalScore = input.float(72.0, "Institutional FVG score", minval=50.0, maxval=100.0, step=1.0, group=GROUP_IMBALANCE)
inp_imbalanceMinWidthAtr = input.float(0.08, "Minimum FVG width ATR", minval=0.01, maxval=2.0, step=0.01, group=GROUP_IMBALANCE)
inp_imbalanceMaxObjects = input.int(180, "Maximum imbalance objects", minval=40, maxval=500, group=GROUP_IMBALANCE)
inp_showImbalanceVisuals = input.bool(true, "Draw imbalance zones", group=GROUP_IMBALANCE)
inp_showImbalanceLabels = input.bool(true, "Draw imbalance labels", group=GROUP_IMBALANCE)

inp_orderBlockMinScore = input.float(58.0, "Minimum order block score", minval=0.0, maxval=100.0, step=1.0, group=GROUP_ORDER_BLOCK)
inp_orderBlockInstitutionalScore = input.float(74.0, "Institutional order block score", minval=50.0, maxval=100.0, step=1.0, group=GROUP_ORDER_BLOCK)
inp_orderBlockSourceWindow = input.int(12, "Source search window", minval=3, maxval=40, group=GROUP_ORDER_BLOCK)
inp_orderBlockZoneMode = input.string("Auto Institutional", "Zone definition", options=["Full Candle", "Body Only", "Open-to-Low/Open-to-High", "Refined Range", "Auto Institutional"], group=GROUP_ORDER_BLOCK)
inp_orderBlockMitigationMode = input.string("Midpoint Touch", "Mitigation tracking", options=["Wick Touch", "Midpoint Touch", "Full Fill", "Close Through"], group=GROUP_ORDER_BLOCK)
inp_orderBlockInvalidationMode = input.string("Close Through", "Invalidation mode", options=["Close Through", "Wick Through"], group=GROUP_ORDER_BLOCK)
