    int index = 0
    while index < array.size(g_signalRegistry.objects)
        SignalObject signalObject = array.get(g_signalRegistry.objects, index)
        if signalObject.publicationStatus == SIGNAL_STATE_DISPATCHED_INTERNAL
            count += 1
