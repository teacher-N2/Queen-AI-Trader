    while index < array.size(g_signalRegistry.objects)
        SignalObject signalObject = array.get(g_signalRegistry.objects, index)
        if signalObject.publicationStatus == SIGNAL_STATE_SUPPRESSED_DUPLICATE or signalObject.publicationStatus == SIGNAL_STATE_SUPPRESSED_CONFIGURATION
            count += 1
        index += 1
    count

f_signalLastPayload() =>
    g_signalRegistry.latestPayload

f_signalLastHumanMessage() =>
    g_signalRegistry.latestHumanMessage

